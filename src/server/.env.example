# Database (Neon PostgreSQL)
DB_NAME=hoangu_lms
DB_USER=your_neon_username
DB_PASSWORD=your_neon_password
DB_PORT=5432
DB_HOST=ep-xxx.us-east-1.aws.neon.tech

# JWT Secret - Generate with: openssl rand -base64 32
JWT_SECRET=your-production-secret-key

# Server
PORT=3000
FRONTEND_URL=https://hoangu.techhave.com
NODE_ENV=development

# Email (Resend)
RESEND_API_KEY=
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@hoangu.tech
EMAIL_FROM_NAME=HoaNgữ LMS

# VNPay (Vietnam Payment Gateway)
VNP_TMNCODE=
VNP_HASHSECRET=
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNP_RETURNURL=http://localhost:5173/payment/return

# Logging
LOG_LEVEL=info
LOG_DIR=logs
