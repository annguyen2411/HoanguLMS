# ==============================================
# HOANGU LMS - Environment Variables
# ==============================================

# ==============================================
# FRONTEND (Vite)
# ==============================================
VITE_API_URL=http://localhost:3000
VITE_APP_NAME=Học Tiếng Trung LMS

# ==============================================
# BACKEND (Express)
# ==============================================
NODE_ENV=production
PORT=3000

# Database - PostgreSQL on VPS
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hoangu_lms
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# ==============================================
# PAYMENT (VNPay)
# ==============================================
VNP_TMNCODE=your_tmncode
VNP_HASH_SECRET=your_hash_secret
VNP_URL=https://sandbox.vnpayment.vn
VNP_RETURNURL=http://localhost:3000/payment/return

# ==============================================
# EMAIL (Resend or SMTP)
# ==============================================
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=noreply@hoangu.techhave.com

# ==============================================
# LOGGING
# ==============================================
LOG_LEVEL=info
LOG_DIR=logs